# Meta / Facebook
META_VERIFY_TOKEN=your_webhook_verify_token_here
META_APP_SECRET=your_meta_app_secret_here
META_ACCESS_TOKEN=your_page_access_token_here
META_PAGE_ID=your_page_id_here

# GoHighLevel
GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=your_ghl_location_id_here
# Comma-separated GHL user IDs for the 8 agents (round-robin assignment)
GHL_AGENT_IDS=agent1_id,agent2_id,agent3_id,agent4_id,agent5_id,agent6_id,agent7_id,agent8_id

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# App
PORT=3000
NODE_ENV=production
